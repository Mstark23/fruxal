# ============================================================
# FRUXAL — Required Environment Variables
# Copy to .env.local and fill in values before deploying
# ============================================================

# ─── NextAuth (REQUIRED) ─────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-domain.vercel.app

# ─── Supabase (REQUIRED) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# ─── Prisma (REQUIRED — same DB as Supabase) ─────────────
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres

# ─── Anthropic AI (REQUIRED) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_MODEL=claude-sonnet-4-20250514

# ─── Stripe (REQUIRED for payments) ──────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── QuickBooks (optional — enables QB integration) ───────
QUICKBOOKS_CLIENT_ID=your-client-id
QUICKBOOKS_CLIENT_SECRET=your-client-secret
QUICKBOOKS_REDIRECT_URI=https://your-domain.vercel.app/api/quickbooks/callback
# Aliases (same as above — QB routes check all three):
QB_CLIENT_ID=your-client-id
QB_CLIENT_SECRET=your-client-secret
QB_REDIRECT_URI=https://your-domain.vercel.app/api/quickbooks/callback
INTUIT_CLIENT_ID=your-client-id
INTUIT_CLIENT_SECRET=your-client-secret
INTUIT_REDIRECT_URI=https://your-domain.vercel.app/api/quickbooks/callback

# ─── Plaid (optional — enables bank integration) ─────────
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# ─── Email (optional — enables notifications) ─────────────
RESEND_API_KEY=re_...
SENDGRID_API_KEY=SG....
EMAIL_FROM=notifications@your-domain.com
EMAIL_FROM_ADDRESS=notifications@your-domain.com
EMAIL_PROVIDER=resend
SALES_EMAIL=sales@your-domain.com

# ─── Cron (recommended — protects cron endpoints) ─────────
CRON_SECRET=generate-random-secret

# ─── App URLs ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link
NEXT_PUBLIC_ADVISOR_CALENDLY_URL=https://calendly.com/your-advisor-link

# ─── Financial Modeling Prep (optional — public company diagnostics) 
FMP_API_KEY=your-fmp-key

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                        # From Google Cloud Console
GOOGLE_CLIENT_SECRET=                    # From Google Cloud Console

# ─── Stripe Price IDs ─────────────────────────────────────────────────────────
STRIPE_PRO_PRICE_ID=                     # price_xxx — Solo Pro monthly
STRIPE_PRO_ANNUAL_PRICE_ID=             # price_xxx — Solo Pro annual
STRIPE_BUSINESS_PRICE_ID=               # price_xxx — Business monthly
STRIPE_BUSINESS_ANNUAL_PRICE_ID=        # price_xxx — Business annual
STRIPE_TEAM_PRICE_ID=                   # price_xxx — Team monthly
STRIPE_TEAM_ANNUAL_PRICE_ID=            # price_xxx — Team annual

# ─── Encryption Keys ──────────────────────────────────────────────────────────
ENCRYPTION_KEY=                          # 32-char hex key for general encryption
STRIPE_ENCRYPTION_KEY=                  # 32-char hex key for Stripe data
PLAID_ENCRYPTION_KEY=                   # 32-char hex key for Plaid tokens
QB_ENCRYPTION_KEY=                      # 32-char hex key for QuickBooks tokens

# ─── Plaid ────────────────────────────────────────────────────────────────────
PLAID_ENV=sandbox                        # sandbox | development | production

# ─── QuickBooks ───────────────────────────────────────────────────────────────
QUICKBOOKS_ENVIRONMENT=sandbox           # sandbox | production

# ─── Analytics & Monitoring (optional) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=                # phc_xxx — PostHog analytics
NEXT_PUBLIC_SENTRY_DSN=                 # https://xxx@sentry.io/xxx

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=you@example.com             # Comma-separated admin email addresses
ADMIN_DEV_BYPASS=false                  # true to bypass admin auth in development

# Calendly
NEXT_PUBLIC_ENTERPRISE_CALENDLY_URL=https://calendly.com/admin-fruxal/enterprise
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-secret

# Email
RESEND_FROM_EMAIL=hello@fruxal.ca

# Stripe Connect (for connected accounts)
STRIPE_CONNECT_CLIENT_ID=ca_xxxx
