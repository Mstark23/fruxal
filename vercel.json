{
  "crons": [
    {
      "path": "/api/v2/cron/daily",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/intelligence/cron",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/rescan",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/outreach",
      "schedule": "0 10 * * 2"
    },
    {
      "path": "/api/v2/cron/monthly-brief",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/v2/cron/score-update",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/v2/cron/benchmarks",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v2/cron/rep-followup",
      "schedule": "0 14 * * 3"
    },
    {
      "path": "/api/v2/cron/agreement-reminder",
      "schedule": "0 15 * * 5"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/prescan",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/v2/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/r/:partnerId",
      "destination": "/api/affiliate/redirect?pid=:partnerId"
    }
  ]
}